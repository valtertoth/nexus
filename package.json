{
  "name": "nexus",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @nexus/web",
    "dev:server": "npm run dev -w @nexus/server",
    "dev": "npm run dev:web & npm run dev:server",
    "build:shared": "npm run build -w @nexus/shared",
    "build:web": "npm run build -w @nexus/web",
    "build:server": "npm run build -w @nexus/server",
    "build": "npm run build:shared && npm run build:web && npm run build:server",
    "test": "npm run test -w @nexus/server"
  }
}
